generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String?       @unique
  phone        String?       @unique
  passwordHash String?
  role         String        @default("MANAGER") // ADMIN, MANAGER, CLIENT, AGENCY
  isActive     Boolean       @default(true)
  guardProfile GuardProfile?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model GuardProfile {
  id               String            @id @default(cuid())
  userId           String            @unique
  user             User              @relation(fields: [userId], references: [id])
  employmentType   String // IN_HOUSE, AGENCY
  agencyId         String?
  preferredShift   String?
  maxWeeklyHours   Int?
  licenseStatus    String?
  rosterSchedules  RosterSchedule[]
  patrolExecutions PatrolExecution[]
}

model Site {
  id                  String               @id @default(cuid())
  clientId            String? // FK to User (Client role)
  siteName            String
  address             String
  status              String               @default("ACTIVE")
  checkpoints         Checkpoint[]
  routes              Route[]
  shiftConfigurations ShiftConfiguration[]
}

model Checkpoint {
  id                String            @id @default(cuid())
  siteId            String
  site              Site              @relation(fields: [siteId], references: [id])
  name              String
  type              String // QR or NFC
  securePayloadUuid String            @unique
  routeCheckpoints  RouteCheckpoint[]
}

model Route {
  id                       String            @id @default(cuid())
  siteId                   String
  site                     Site              @relation(fields: [siteId], references: [id])
  name                     String
  estimatedDurationMinutes Int
  routeCheckpoints         RouteCheckpoint[]
  patrolExecutions         PatrolExecution[]
}

model RouteCheckpoint {
  id               String     @id @default(cuid())
  routeId          String
  route            Route      @relation(fields: [routeId], references: [id])
  checkpointId     String
  checkpoint       Checkpoint @relation(fields: [checkpointId], references: [id])
  sequenceOrder    Int
  toleranceMinutes Int?
}

model ShiftConfiguration {
  id              String           @id @default(cuid())
  siteId          String
  site            Site             @relation(fields: [siteId], references: [id])
  shiftName       String
  startTime       String // Time format (e.g., "08:00")
  endTime         String
  guardsRequired  Int              @default(1)
  rosterSchedules RosterSchedule[]
}

model RosterSchedule {
  id            String             @id @default(cuid())
  shiftConfigId String
  shiftConfig   ShiftConfiguration @relation(fields: [shiftConfigId], references: [id])
  guardId       String
  guard         GuardProfile       @relation(fields: [guardId], references: [id])
  date          DateTime
  status        String
}

model PatrolExecution {
  id        String       @id @default(cuid())
  routeId   String
  route     Route        @relation(fields: [routeId], references: [id])
  guardId   String
  guard     GuardProfile @relation(fields: [guardId], references: [id])
  startTime DateTime
  endTime   DateTime?
  status    String // IN_PROGRESS, COMPLETED, MISSED
}
